# คัดลอกเป็นไฟล์ `.env` ในโฟลเดอร์เดียวกัน (`cp .env.example .env`)
# ถ้าไม่มี `.env` โปรแกรมใช้ค่าเริ่มต้น SKIP_AUTH=false → ต้องตั้ง JWT_SECRET อย่างน้อย 16 ตัวอักษร
# See backend/README.md + docs/BACKEND_STRUCTURE.md

NODE_ENV=development
PORT=5000

# MariaDB — ชื่อฐานล็อก: pepsi_pm (database/README.md)
DATABASE_HOST=127.0.0.1
# MariaDB default port is 3306 — match your server (e.g. DBeaver / docker publish)
DATABASE_PORT=3306
DATABASE_USER=pepsi_pm_app
DATABASE_PASSWORD=change_me
DATABASE_NAME=pepsi_pm

# CORS — frontend Vite (คั่นหลาย origin ด้วย comma; localhost กับ 127.0.0.1 ไม่เท่ากันในเบราว์เซอร์)
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Dev only: skip JWT and attach a stub user (remove in production)
SKIP_AUTH=true

# When SKIP_AUTH=false: HS256 JWT — required min 16 chars
# JWT_SECRET=replace_with_long_random_secret

# Token lifetime (e.g. 8h, 7d)
# JWT_EXPIRES_IN=8h

# Dev only: POST /api/v1/auth/dev-token — mint JWT for existing users.gpid
# DEV_AUTH_SECRET=replace_with_dev_only_secret

# Reject file upload if same SHA256 already exists for that source_kind (requires migration index on batches)
# DEDUPE_REJECT_DUPLICATE_FILE_SHA=false

# Worker idle interval (ms) — `npm run worker`
# WORKER_POLL_MS=2000

# ไฟล์แนบ task_log (รูป → WebP บนดิสก์) — ดู docs/MEDIA_WEBP_POLICY.md
# ATTACHMENTS_DIR=data/attachments
# ATTACHMENTS_MAX_FILE_BYTES=15728640
# ATTACHMENTS_USE_SHARP=true

